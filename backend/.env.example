# =============================================
# CRM System - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local:  mongodb://localhost:27017/crm_system
# Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/crm_system
MONGODB_URI=mongodb://localhost:27017/crm_system

# JWT Secret Key (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# JWT Expiry
JWT_EXPIRE=7d

# Admin Seed Credentials (used only for first-time setup)
ADMIN_EMAIL=admin@crm.com
ADMIN_PASSWORD=Admin@123

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
