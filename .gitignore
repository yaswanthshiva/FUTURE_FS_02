# =============================================
# .gitignore — Never commit these files
# =============================================

# Environment variables (contains secrets!)
.env
.env.local
.env.production

# Dependencies (re-installed via npm install)
node_modules/
*/node_modules/

# Build outputs
build/
dist/
frontend/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor config
.vscode/
.idea/
*.swp
*.swo

# Testing
coverage/
